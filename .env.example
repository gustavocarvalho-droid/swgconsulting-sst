# SWG Consulting SST — Variáveis de Ambiente
# Copie este arquivo para .env e preencha as variáveis

# Anthropic API Key (obrigatória para Buscador e IA)
ANTHROPIC_API_KEY=sk-ant-...

# Neon PostgreSQL (banco de dados na nuvem)
# Obtenha em: https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Vercel KV (opcional — fallback do WA module)
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
